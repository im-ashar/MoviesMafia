@* Color-coded TMDB vote average badge. *@

<span class="@CssClass">★ @Score.ToString("0.0")</span>

@code {
    [Parameter] public double Score { get; set; }

    private string CssClass
    {
        get
        {
            var tone = Score switch
            {
                >= 8 => "bg-emerald-500/15 text-emerald-300 border-emerald-500/30",
                >= 5 => "bg-amber-500/15 text-amber-300 border-amber-500/30",
                _ => "bg-primary-container/15 text-primary border-primary/30",
            };
            return $"inline-flex items-center gap-1 rounded-md border px-2 py-0.5 text-xs font-semibold tabular-nums {tone}";
        }
    }
}
