@* Color-coded TMDB vote average badge. *@

<span class="@CssClass">★ @Score.ToString("0.0")</span>

@code {
    [Parameter] public double Score { get; set; }

    private string CssClass
    {
        get
        {
            var tone = Score switch
            {
                >= 8 => "text-emerald-300 ring-emerald-400/40",
                >= 5 => "text-amber-300 ring-amber-400/40",
                _ => "text-rose-300 ring-rose-400/40",
            };
            // Always sit on a dark blurred chip so the score stays readable on bright posters.
            return $"inline-flex items-center gap-1 rounded-md bg-black/55 px-2 py-0.5 text-xs font-semibold tabular-nums ring-1 backdrop-blur {tone}";
        }
    }
}
