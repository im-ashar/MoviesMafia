@* Presentational poster card for a movie or series. Hover reveal uses Alpine (client-only). *@

<div class="group card overflow-hidden" x-data="{ hover: false }"
     @@mouseenter="hover = true" @@mouseleave="hover = false">
    <div class="relative aspect-[2/3] overflow-hidden bg-surface-container-high">
        @if (PosterUrl is not null)
        {
            <img src="@PosterUrl" alt="@Title poster" loading="lazy"
                 class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" />
        }
        else
        {
            <div class="flex h-full items-center justify-center text-on-surface-variant">No image</div>
        }

        <div class="absolute right-2 top-2">
            <RatingBadge Score="Score" />
        </div>

        @if (!string.IsNullOrWhiteSpace(Overview))
        {
            <div class="absolute inset-0 flex items-end bg-gradient-to-t from-ink via-ink/70 to-transparent p-3 opacity-0 transition-opacity duration-200 group-hover:opacity-100">
                <p class="line-clamp-5 text-xs text-on-surface/90">@Overview</p>
            </div>
        }
    </div>

    <div class="p-3">
        <h3 class="truncate text-sm font-semibold" title="@Title">@Title</h3>
        @if (!string.IsNullOrWhiteSpace(Year))
        {
            <p class="text-xs text-on-surface-variant">@Year</p>
        }
        <div class="mt-3 flex gap-2">
            <a href="@TrailerUrl" class="btn-ghost flex-1 px-2 py-1.5 text-xs">Trailer</a>
            <a href="@WatchUrl" class="btn-primary flex-1 px-2 py-1.5 text-xs">Watch</a>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public string Title { get; set; } = "";
    [Parameter] public string? PosterUrl { get; set; }
    [Parameter] public string? Overview { get; set; }
    [Parameter] public string? Year { get; set; }
    [Parameter] public double Score { get; set; }
    [Parameter, EditorRequired] public string TrailerUrl { get; set; } = "";
    [Parameter, EditorRequired] public string WatchUrl { get; set; } = "";
}
