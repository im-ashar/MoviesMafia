@inherits ReactiveBlazor.ReactiveComponent
@using MoviesMafia.Services.Tmdb
@using MoviesMafia.Services.Tmdb.Dtos
@inject ITmdbClient Tmdb

@* What's Popular row with Movies / Series filter. State lives server-side. *@
<ReactiveRoot Owner="this">
    <section class="mt-14 sm:mt-16">
        <header class="mb-4 flex flex-wrap items-end justify-between gap-4">
            <div>
                <h2 class="text-2xl font-bold sm:text-3xl">What's popular</h2>
                <p class="mt-1 text-sm text-on-surface-variant">Hand-picked from TMDB's most-loved titles.</p>
            </div>
            <div class="inline-flex rounded-full border border-line bg-surface p-1 text-sm">
                <button type="button" class="@TabClass("movies")" data-on-click="SetMovies">Movies</button>
                <button type="button" class="@TabClass("series")" data-on-click="SetSeries">Series</button>
            </div>
        </header>

        <div class="relative"
             x-data="rowScroller">
            <button type="button" x-on:click="scroll(-1)"
                    class="absolute left-0 top-1/2 z-10 hidden -translate-x-2 -translate-y-1/2 rounded-full border border-line bg-surface/90 p-2 text-content shadow-lg backdrop-blur transition hover:bg-surface sm:flex"
                    aria-label="Scroll left">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 11-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
                </svg>
            </button>

            <div x-ref="row" class="scrollbar-hide -mx-2 flex snap-x snap-mandatory gap-4 overflow-x-auto scroll-smooth px-2 pb-2">
                @if (Items.Count == 0)
                {
                    <p class="px-2 py-10 text-on-surface-variant">Nothing to show right now.</p>
                }
                else
                {
                    @foreach (var c in Items)
                    {
                        <div class="w-44 shrink-0 snap-start sm:w-52">
                            <MediaCard Title="@c.Title"
                                       PosterUrl="@c.PosterUrl"
                                       Overview="@c.Overview"
                                       Year="@c.Year"
                                       Score="c.Score"
                                       TrailerUrl="@c.TrailerUrl"
                                       WatchUrl="@c.WatchUrl"
                                       DetailsUrl="@c.DetailsUrl" />
                        </div>
                    }
                }
            </div>

            <button type="button" x-on:click="scroll(1)"
                    class="absolute right-0 top-1/2 z-10 hidden translate-x-2 -translate-y-1/2 rounded-full border border-line bg-surface/90 p-2 text-content shadow-lg backdrop-blur transition hover:bg-surface sm:flex"
                    aria-label="Scroll right">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                </svg>
            </button>

        </div>
    </section>
</ReactiveRoot>

@code {
    public string Kind { get; set; } = "movies";

    [ReactiveIgnore]
    public List<Card> Items { get; set; } = [];

    protected override async Task OnInitializedAsync() => await LoadAsync();

    [ReactiveAction]
    public void SetMovies() => Kind = "movies";

    [ReactiveAction]
    public void SetSeries() => Kind = "series";

    private async Task LoadAsync()
    {
        try
        {
            if (Kind == "series")
            {
                var page = await Tmdb.GetPopularSeriesAsync();
                Items = page.Results.Take(16).Select(s => new Card(
                    s.Name ?? "Untitled",
                    Tmdb.ImageUrl(s.PosterPath),
                    s.Overview,
                    Year(s.FirstAirDate),
                    s.VoteAverage,
                    $"/trailer/series/{s.Id}",
                    $"/watch/series/{s.Id}",
                    $"/details/series/{s.Id}")).ToList();
            }
            else
            {
                var page = await Tmdb.GetPopularMoviesAsync();
                Items = page.Results.Take(16).Select(m => new Card(
                    m.Title ?? "Untitled",
                    Tmdb.ImageUrl(m.PosterPath),
                    m.Overview,
                    Year(m.ReleaseDate),
                    m.VoteAverage,
                    $"/trailer/movie/{m.Id}",
                    $"/watch/movie/{m.Id}",
                    $"/details/movie/{m.Id}")).ToList();
            }
        }
        catch
        {
            Items = [];
        }
    }

    private string TabClass(string value) =>
        Kind == value
            ? "rounded-full px-4 py-1.5 font-semibold transition bg-brand text-white"
            : "rounded-full px-4 py-1.5 font-semibold transition text-content/70 hover:text-content hover:bg-surface-2/60";

    private static string? Year(string? date) =>
        !string.IsNullOrEmpty(date) && date.Length >= 4 ? date[..4] : null;

    public sealed record Card(
        string Title, string? PosterUrl, string? Overview, string? Year,
        double Score, string TrailerUrl, string WatchUrl, string DetailsUrl);
}
