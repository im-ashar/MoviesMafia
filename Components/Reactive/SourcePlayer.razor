@inherits ReactiveBlazor.ReactiveComponent
@attribute [Authorize]
@using MoviesMafia.Services.Streaming
@inject IEmbedUrlBuilder Embed

@* Source switcher: the active provider index lives in server state; clicking a
   source button dispatches an action that morphs the iframe src in place.

   IMPORTANT: [Parameter] props are NOT serialized into the reactive state token, and
   the parent page is not re-rendered on a dispatch — so on every click TmdbId/IsSeries/
   Season/Episode would arrive as their defaults. We therefore mirror them into plain
   public *state* properties (MediaId/Series/SeasonNo/EpisodeNo) on the initial render,
   and those survive each round-trip. _sources is rebuilt from that restored state. *@
<ReactiveRoot Owner="this">
    <div class="scroll-mt-32" id="player">
        @if (_sources.Count == 0)
        {
            <div class="card p-10 text-center text-on-surface-variant">No playback sources are configured.</div>
        }
        else
        {
            @* Controls row above the player: source picker (left) + ad-blocker note (right),
               splitting the width 50/50 on desktop and stacking on mobile so neither is cramped. *@
            <div class="mb-3 flex flex-col gap-3 sm:flex-row sm:items-stretch">
                @if (_sources.Count > 1)
                {
                    @* Source picker dropdown. Scales to any number of providers: a compact trigger
                       showing the active source, opening a scrollable, searchable panel. Selecting
                       an item is a reactive round-trip (data-on-click) that morphs the iframe; the
                       panel is server-rendered closed (style="display:none") so a morph keeps it shut. *@
                    <div class="relative w-full sm:w-1/2"
                         x-data="{ open: false, q: '' }" x-on:click.outside="open = false" x-on:keydown.escape="open = false">
                        <button type="button"
                                class="flex h-full w-full items-center justify-between gap-3 rounded-xl border border-line bg-surface/70 px-4 py-2.5 text-sm text-content transition hover:bg-surface-2/60"
                                x-on:click="open = !open" x-bind:aria-expanded="open">
                            <span class="flex min-w-0 items-center gap-2">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 shrink-0 text-brand" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                    <path d="M6 4.5v11a.5.5 0 0 0 .77.42l9-5.5a.5.5 0 0 0 0-.84l-9-5.5A.5.5 0 0 0 6 4.5z" />
                                </svg>
                                <span class="truncate font-medium">@CurrentName</span>
                            </span>
                            <span class="flex shrink-0 items-center gap-2 text-muted">
                                <span class="rounded-full bg-surface-2 px-2 py-0.5 text-xs">@_sources.Count</span>
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition" x-bind:class="open && 'rotate-180'" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                    <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.085l3.71-3.855a.75.75 0 1 1 1.08 1.04l-4.25 4.41a.75.75 0 0 1-1.08 0L5.21 8.27a.75.75 0 0 1 .02-1.06z" clip-rule="evenodd" />
                                </svg>
                            </span>
                        </button>

                        <div x-show="open" x-cloak x-transition style="display:none"
                             class="absolute left-0 z-30 mt-2 w-full overflow-hidden rounded-xl border border-line bg-surface shadow-[var(--shadow-2xl)]">
                            @* Filter box — handy once the provider list gets long. *@
                            <div class="border-b border-line/70 p-2">
                                <input type="text" x-model="q" placeholder="Filter sources…"
                                       class="w-full rounded-lg border border-line bg-surface-2/60 px-3 py-2 text-sm text-content placeholder:text-muted focus:border-brand focus:outline-none"
                                       x-on:click.stop />
                            </div>
                            <div class="max-h-72 overflow-y-auto py-1">
                                @for (var i = 0; i < _sources.Count; i++)
                                {
                                    var idx = i;
                                    var isActive = idx == ActiveIndex;
                                    var name = _sources[idx].Name;
                                    <button type="button" data-on-click="Select" data-args="@($"[{idx}]")"
                                            x-on:click="open = false"
                                            x-show="q === '' || '@name.ToLowerInvariant()'.includes(q.toLowerCase())"
                                            class="@($"flex w-full items-center gap-3 px-4 py-2.5 text-left text-sm transition {(isActive ? "bg-brand/15 text-content" : "text-content/80 hover:bg-surface-2/60")}")">
                                        <span class="@($"flex h-5 w-5 shrink-0 items-center justify-center rounded-full text-xs {(isActive ? "bg-brand text-white" : "border border-line text-transparent")}")">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                                                <path fill-rule="evenodd" d="M16.7 5.3a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0l-3.5-3.5a1 1 0 1 1 1.4-1.4l2.8 2.79 6.8-6.79a1 1 0 0 1 1.4 0z" clip-rule="evenodd" />
                                            </svg>
                                        </span>
                                        <span class="flex-1 truncate">@name</span>
                                    </button>
                                }
                            </div>
                        </div>
                    </div>
                }

                @* Ad-blocker advisory note (right half). Dismissal persists in localStorage
                   (playbackTip in app.js) so it survives reloads and the Idiomorph subtree swaps on
                   episode switches. x-cloak + server-rendered style keep it from flashing. *@
                <div x-data="playbackTip" x-show="show" x-cloak x-transition style="display:none"
                     class="@($"flex w-full items-start gap-3 rounded-xl border border-amber-400/30 bg-amber-400/10 px-4 py-3 text-sm {(_sources.Count > 1 ? "sm:w-1/2" : "")}")">
                    <svg xmlns="http://www.w3.org/2000/svg" class="mt-0.5 h-5 w-5 shrink-0 text-amber-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                        <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.515 2.625H3.72c-1.345 0-2.188-1.458-1.515-2.625L8.485 2.495zM10 6a.75.75 0 0 1 .75.75v3.5a.75.75 0 0 1-1.5 0v-3.5A.75.75 0 0 1 10 6zm0 8a1 1 0 1 0 0-2 1 1 0 0 0 0 2z" clip-rule="evenodd" />
                    </svg>
                    <div class="min-w-0 flex-1">
                        <p class="font-medium text-content">Heads up</p>
                        <p class="mt-0.5 text-on-surface-variant">
                            This player streams from a third-party provider that may show pop-up ads.
                            Using a reputable ad blocker is strongly recommended for the best experience.
                        </p>
                    </div>
                    <button type="button" x-on:click="dismiss()" aria-label="Dismiss"
                            class="shrink-0 rounded-lg p-1 text-on-surface-variant transition hover:bg-surface-2/60 hover:text-content">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path d="M6.28 5.22a.75.75 0 0 0-1.06 1.06L8.94 10l-3.72 3.72a.75.75 0 1 0 1.06 1.06L10 11.06l3.72 3.72a.75.75 0 1 0 1.06-1.06L11.06 10l3.72-3.72a.75.75 0 0 0-1.06-1.06L10 8.94 6.28 5.22z" />
                        </svg>
                    </button>
                </div>
            </div>

            <div class="aspect-video w-full overflow-hidden rounded-xl border border-white/10 bg-black shadow-[var(--shadow-2xl)]">
                <iframe src="@CurrentUrl" class="h-full w-full" allowfullscreen
                        referrerpolicy="origin" ></iframe>
            </div>
        }
    </div>
</ReactiveRoot>

@code {
    // Seed values supplied by the parent page — present on the INITIAL SSR render only.
    [Parameter] public int TmdbId { get; set; }
    [Parameter] public bool IsSeries { get; set; }
    [Parameter] public int Season { get; set; } = 1;
    [Parameter] public int Episode { get; set; } = 1;

    // Serialized reactive state — these DO survive every dispatch round-trip.
    public int MediaId { get; set; }
    public bool Series { get; set; }
    public int SeasonNo { get; set; } = 1;
    public int EpisodeNo { get; set; } = 1;
    public int ActiveIndex { get; set; }

    // Private field — not part of state; rebuilt from the restored identity on each render.
    private IReadOnlyList<EmbedSource> _sources = Array.Empty<EmbedSource>();

    private string CurrentUrl =>
        _sources.Count == 0 ? "" : _sources[Math.Clamp(ActiveIndex, 0, _sources.Count - 1)].Url;

    private string CurrentName =>
        _sources.Count == 0 ? "Source" : _sources[Math.Clamp(ActiveIndex, 0, _sources.Count - 1)].Name;

    protected override void OnParametersSet()
    {
        // Initial render: the parent passes real parameters → copy them into state.
        // On dispatches the parent isn't re-rendered, so TmdbId arrives as 0; keep the
        // values rehydrated from the serialized state token instead.
        if (TmdbId != 0)
        {
            MediaId = TmdbId;
            Series = IsSeries;
            SeasonNo = Season < 1 ? 1 : Season;
            EpisodeNo = Episode < 1 ? 1 : Episode;
        }

        _sources = Series ? Embed.Episode(MediaId, SeasonNo, EpisodeNo) : Embed.Movie(MediaId);

        // Keep the selection in range if the provider list shrank.
        if (ActiveIndex >= _sources.Count) ActiveIndex = Math.Max(0, _sources.Count - 1);
    }

    [ReactiveAction]
    public void Select(int index)
    {
        // Don't validate against _sources here: actions run BEFORE the re-render, so
        // _sources isn't built yet. Just record the choice; OnParametersSet clamps it.
        if (index >= 0) ActiveIndex = index;
    }
}
