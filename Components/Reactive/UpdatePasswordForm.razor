@inherits ReactiveBlazor.ReactiveComponent
@attribute [Authorize]
@using Microsoft.AspNetCore.Identity
@using MoviesMafia.Domain.Entities
@inject UserManager<AppUser> UserManager
@inject IHttpContextAccessor Http

@* Change password with inline result — no page reload. *@
<ReactiveRoot Owner="this">
    <div>
        <StatusMessage IsError="@_isError" Message="@_message" />

        <div class="space-y-3">
            <div>
                <label class="label">Current password</label>
                <input class="input" type="password" data-bind="CurrentPassword" value="@CurrentPassword" />
            </div>
            <div>
                <label class="label">New password</label>
                <input class="input" type="password" data-bind="NewPassword" value="@NewPassword" />
            </div>
            <div>
                <label class="label">Confirm new password</label>
                <input class="input" type="password" data-bind="ConfirmPassword" value="@ConfirmPassword" />
            </div>
        </div>
        <button type="button" class="btn-primary mt-4" data-on-click="Save">Update password</button>
    </div>
</ReactiveRoot>

@code {
    public string CurrentPassword { get; set; } = string.Empty;
    public string NewPassword { get; set; } = string.Empty;
    public string ConfirmPassword { get; set; } = string.Empty;

    private string? _message;
    private bool _isError;

    [ReactiveAction]
    public async Task Save()
    {
        if (NewPassword != ConfirmPassword)
        {
            Set("New password and confirmation do not match.", error: true);
            return;
        }

        var user = await UserManager.GetUserAsync(Http.HttpContext!.User);
        if (user is null)
        {
            Set("Your session has expired. Please sign in again.", error: true);
            return;
        }

        var result = await UserManager.ChangePasswordAsync(user, CurrentPassword, NewPassword);
        if (result.Succeeded)
        {
            Set("Password updated successfully.", error: false);
            CurrentPassword = NewPassword = ConfirmPassword = string.Empty;
        }
        else
        {
            Set(string.Join(" ", result.Errors.Select(e => e.Description)), error: true);
        }
    }

    private void Set(string message, bool error)
    {
        _message = message;
        _isError = error;
    }
}
