@page "/series"
@using MoviesMafia.Services.Tmdb
@using MoviesMafia.Services.Tmdb.Dtos
@inject ITmdbClient Tmdb

<PageTitle>Series — MoviesMafia</PageTitle>

<HeroCarousel Slides="_hero" />

<div class="w-full px-4 pb-16 sm:px-6 lg:px-10">

    @if (_loadError is not null)
    {
        <StatusMessage IsError="true" Message="@_loadError" />
    }

    <TrendingSection Kind="series" />

    <MediaRow Title="Popular series" Subtitle="The shows everyone's binging">
        @foreach (var s in _popular)
        {
            @Card(s)
        }
    </MediaRow>

    <MediaRow Title="On the air" Subtitle="Series with new episodes airing now">
        @foreach (var s in _onTheAir)
        {
            @Card(s)
        }
    </MediaRow>

    <MediaRow Title="Airing today" Subtitle="Fresh episodes in the next 24 hours">
        @foreach (var s in _airingToday)
        {
            @Card(s)
        }
    </MediaRow>

    <MediaRow Title="Top rated series" Subtitle="Binge-worthy classics">
        @foreach (var s in _topRated)
        {
            @Card(s)
        }
    </MediaRow>
</div>

@code {
    private const int RowSize = HomeMappers.RowSize;

    private List<HeroSlide> _hero = new();
    private List<SeriesResult> _popular = new();
    private List<SeriesResult> _onTheAir = new();
    private List<SeriesResult> _airingToday = new();
    private List<SeriesResult> _topRated = new();
    private string? _loadError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var heroTask = Tmdb.GetTrendingSeriesAsync("day");
            var popularTask = Tmdb.GetPopularSeriesAsync();
            var onTheAirTask = Tmdb.GetOnTheAirSeriesAsync();
            var airingTodayTask = Tmdb.GetAiringTodaySeriesAsync();
            var topRatedTask = Tmdb.GetTopRatedSeriesAsync();

            await Task.WhenAll(heroTask, popularTask, onTheAirTask, airingTodayTask, topRatedTask);

            _hero = HomeMappers.ToHeroSlides((await heroTask).Results, Tmdb, "Trending series");
            _popular = (await popularTask).Results.Take(RowSize).ToList();
            _onTheAir = (await onTheAirTask).Results.Take(RowSize).ToList();
            _airingToday = (await airingTodayTask).Results.Take(RowSize).ToList();
            _topRated = (await topRatedTask).Results.Take(RowSize).ToList();
        }
        catch
        {
            _loadError = "We couldn't load series right now. Please try again shortly.";
        }
    }

    private RenderFragment Card(SeriesResult s) =>
        @<div class="w-44 shrink-0 snap-start sm:w-52">
            <MediaCard Title="@(s.Name ?? "Untitled")"
                       PosterUrl="@Tmdb.ImageUrl(s.PosterPath)"
                       Overview="@s.Overview"
                       Year="@HomeMappers.Year(s.FirstAirDate)"
                       Score="s.VoteAverage"
                       TrailerUrl="@($"/trailer/series/{s.Id}")"
                       WatchUrl="@($"/watch/series/{s.Id}")"
                       DetailsUrl="@($"/details/series/{s.Id}")" />
        </div>;
}
