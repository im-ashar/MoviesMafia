@page "/trailer/{Type}/{TmdbId:int}"

<PageTitle>Trailer — MoviesMafia</PageTitle>

<div class="w-full px-4 py-8 sm:px-6 lg:px-10">
<div class="mx-auto max-w-4xl">
    <div class="mb-4 flex items-center justify-between">
        <h1 class="text-2xl font-bold">Trailers</h1>
        <a href="@WatchUrl" class="btn-primary">Watch now</a>
    </div>

    <TrailerPlayer TmdbId="TmdbId" MediaKind="@Type" />
</div>
</div>

@code {
    [Parameter] public string Type { get; set; } = "movie";
    [Parameter] public int TmdbId { get; set; }

    private string WatchUrl => $"/watch/{Type}/{TmdbId}";
}
