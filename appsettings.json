{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Tmdb": {
    "ApiKey": "",
    "BaseUrl": "https://api.themoviedb.org/3/",
    "ImageBaseUrl": "https://image.tmdb.org/t/p/"
  },
  "Streaming": {
    "Providers": [
      {
        "Name": "AutoEmbed",
        "MovieTemplate": "https://autoembed.co/movie/tmdb/{id}",
        "EpisodeTemplate": "https://autoembed.co/tv/tmdb/{id}-{season}-{episode}"
      },
      {
        "Name": "VixSrc",
        "MovieTemplate": "https://vixsrc.to/movie/{id}?autoPlay=true&lang=en",
        "EpisodeTemplate": "https://vixsrc.to/tv/{id}/{season}/{episode}?autoPlay=true&lang=en"
      },
      {
        "Name": "MoviesAPI",
        "MovieTemplate": "https://moviesapi.to/movie/{id}",
        "EpisodeTemplate": "https://moviesapi.to/tv/{id}-{season}-{episode}"
      },
      {
        "Name": "VidSrc",
        "MovieTemplate": "https://vidsrc.me/embed/movie?tmdb={id}&autoplay=1",
        "EpisodeTemplate": "https://vidsrc.me/embed/tv?tmdb={id}&season={season}&episode={episode}&autoplay=1"
      },
      {
        "Name": "Videasy",
        "MovieTemplate": "https://player.videasy.net/movie/{id}",
        "EpisodeTemplate": "https://player.videasy.net/tv/{id}/{season}/{episode}?nextEpisode=true&episodeSelector=true"
      },
      {
        "Name": "VidFast",
        "MovieTemplate": "https://vidfast.pro/movie/{id}?autoPlay=true",
        "EpisodeTemplate": "https://vidfast.pro/tv/{id}/{season}/{episode}?autoPlay=true"
      },
      {
        "Name": "VidLink",
        "MovieTemplate": "https://vidlink.pro/movie/{id}?title=true&poster=true&autoplay=true",
        "EpisodeTemplate": "https://vidlink.pro/tv/{id}/{season}/{episode}?title=true&poster=true&autoplay=true&nextbutton=true"
      }
    ]
  },
  "Storage": {
    "AvatarsPath": "App_Data/avatars",
    "AvatarsRequestPath": "/avatars"
  },
  "Smtp": {
    "Host": "",
    "Port": 587,
    "UserName": "",
    "Password": "",
    "FromAddress": "no-reply@moviesmafia.local",
    "FromName": "MoviesMafia",
    "EnableSsl": true
  },
  "AdminSeed": {
    "UserName": "",
    "Email": "",
    "Password": "",
    "ProfilePictureFileName": ""
  }
}
